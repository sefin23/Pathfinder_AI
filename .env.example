# Pathfinder AI — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── SMTP Configuration ──────────────────────────────────────────────────────
# Gmail example: use an App Password (not your account password).
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# The "From" name and address shown in the user's inbox
EMAIL_FROM=Pathfinder AI <no-reply@pathfinder.ai>

# ── Retry Settings ───────────────────────────────────────────────────────────
# Max attempts before giving up on a single email
EMAIL_MAX_RETRIES=3
# Base delay in seconds between retries (doubles each attempt: 5s, 10s, 20s)
EMAIL_RETRY_DELAY=5

# ── Runtime Environment ──────────────────────────────────────────────────────
# Set to "production" in deployment. "development" enables console fallback.
APP_ENV=development

# ── NLP / AI (Layer 3) ───────────────────────────────────────────────────────
# Google AI Studio API key for Gemini structured output.
# Generate at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# OpenRouter key (currently fallback only)
OPENROUTER_API_KEY=your-openrouter-key

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite for local dev. Swap for PostgreSQL in production.
# SQLALCHEMY_DATABASE_URL=postgresql://user:password@localhost/pathfinder
